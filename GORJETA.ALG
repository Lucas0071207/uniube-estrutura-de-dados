Algoritmo "Gorjeta"
//
//
// DescriÓÐo   : Aqui vocõ descreve o que o programa faz! (funÓÐo)
// Autor(a)    : Nome do(a) aluno(a)
// Data atual  : 02/04/2026
Var
   VT, V, G, S:real


Inicio
  Escreval("O quanto foi gasto: ")
  Leia(V)
  
  G <- V*(10/100)
  VT <- G + V
  
  Escreval("Gorjeta:",G)
  Escreval("Valor total:",VT)

Fimalgoritmo