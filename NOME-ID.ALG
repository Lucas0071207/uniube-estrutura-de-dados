Algoritmo "nome-id"
//
//
// Descrição   : Aqui você descreve o que o programa faz! (função)
// Autor(a)    : Nome do(a) aluno(a)
// Data atual  : 02/04/2026
Var
   N:caractere
   I:inteiro


Inicio
   Escreval("Informe seu nome e idade:")
   Leia(N,I)
   Escreval("“Olá ", N,  " Você tem",  I," anos")

Fimalgoritmo